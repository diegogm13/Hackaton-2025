{
  "expo": {
    "name": "Holos",
    "slug": "Holos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Holos necesita acceso al micrófono para transcribir tus mensajes de voz.",
        "NSSpeechRecognitionUsageDescription": "Holos usa reconocimiento de voz para convertir tu audio en texto.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.pedro287373.Holos"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.pedro287373.Holos"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-speech-recognition",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "8d004c32-fbee-4c1c-bef7-dd68201ca321"
      }
    }
  }
}
